rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verifica si el usuario está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Verifica si el usuario es el propietario del documento
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Verifica si el usuario es un administrador u operador del sistema
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol == 'admin_global' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_owner == true);
    }

    // --- REGLAS PÚBLICAS (Para visitantes de la Landing Page sin iniciar sesión) ---
    
    // CMS y Bloques: Textos de las Landing Pages, Legales (términos y condiciones), imágenes, etc.
    match /cms/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /cms_blocks/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Catálogo de Excursiones y Experiencias
    match /experiences/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Reservas de Excursiones (los clientes pueden crear reservas públicas)
    match /experience_reservations/{document=**} {
      allow read, write: if isAuthenticated();
      allow create: if true;
    }

    // Tarifas, Sucursales y Categorías (requerido para cotizadores y listados públicos)
    match /tariffs/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /categories/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /branches/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
    match /rewards_catalog/{document=**} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // --- REGLAS GENERALES OPERATIVAS (Para Webhooks, CRM, App y Administradores) ---

    // Permite lectura y escritura de cualquier documento a usuarios autenticados (Vercel, CRM, app móvil)
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
