# =============================================================================
# TRAVELAPP ECOSYSTEM — Plantilla de Variables de Entorno
# Copiá este archivo como .env.local y completá los valores reales
# ⚠️  Este archivo SÍ se versiona en Git (no contiene secretos reales)
# =============================================================================

# -----------------------------------------------------------------------------
# FIREBASE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# -----------------------------------------------------------------------------
# GOOGLE MAPS
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# TRAVIS AI (Google Cloud Function)
# -----------------------------------------------------------------------------
TRAVIS_WEBHOOK_URL=
TRAVIS_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# ZAPIER — Webhooks
# -----------------------------------------------------------------------------
ZAPIER_WEBHOOK_NEW_LEAD=
ZAPIER_WEBHOOK_NEW_BOOKING=
ZAPIER_WEBHOOK_REWARDS=
ZAPIER_WEBHOOK_PARTNER_ONBOARDING=

# -----------------------------------------------------------------------------
# MANYCHAT
# -----------------------------------------------------------------------------
MANYCHAT_API_TOKEN=
MANYCHAT_TRAVIS_RESPONSE_FIELD_ID=
MANYCHAT_INCOMING_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# MERCADO PAGO — Checkout Pro + Split de Pagos (Marketplace)
# Obtener en: https://www.mercadopago.com.ar/developers/panel
# -----------------------------------------------------------------------------
# Clave pública (frontend) — se puede exponer al cliente
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Access Token privado (backend) — NUNCA expongas al cliente
MP_ACCESS_TOKEN=

# Para el flujo OAuth de conductores (MP Connect / Marketplace)
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# URL de retorno OAuth (debe coincidir con la configurada en MP Dashboard)
# En producción: https://travelapp-ecosystem.vercel.app/api/mp/oauth/callback
MP_OAUTH_REDIRECT_URI=http://localhost:3000/api/mp/oauth/callback

# Porcentaje de comisión que retiene TravelCab (ej: 15 = 15%)
MP_MARKETPLACE_FEE_PERCENTAGE=15

# -----------------------------------------------------------------------------
# APLICACIÓN
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
